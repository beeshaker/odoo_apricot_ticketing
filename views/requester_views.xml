<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Requester List View -->
    <record id="view_apricot_requester_list" model="ir.ui.view">
        <field name="name">apricot.ticket.requester.list</field>
        <field name="model">apricot.ticket.requester</field>
        <field name="arch" type="xml">
            <list string="Requesters">
                <field name="name"/>
                <field name="whatsapp_number"/>
                <field name="property_id"/>
                <field name="unit_number"/>
                <field name="terms_accepted"/>
                <field name="ticket_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Requester Form View -->
    <record id="view_apricot_requester_form" model="ir.ui.view">
        <field name="name">apricot.ticket.requester.form</field>
        <field name="model">apricot.ticket.requester</field>
        <field name="arch" type="xml">
            <form string="Requester">
                <header>
                    <button name="action_accept_terms"
                            type="object"
                            string="Accept Terms"
                            class="btn-primary"
                            invisible="terms_accepted"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tickets"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-ticket">
                            <field name="ticket_count"
                                   widget="statinfo"
                                   string="Tickets"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="whatsapp_number"/>
                            <field name="partner_id"/>
                            <field name="active"/>
                        </group>

                        <group>
                            <field name="property_id"/>
                            <field name="unit_number"/>
                            <field name="terms_accepted"/>
                            <field name="terms_accepted_at" readonly="1"/>
                        </group>
                    </group>

                    <group string="WhatsApp Session Info">
                        <field name="last_action"/>
                        <field name="last_action_timestamp"/>
                        <field name="temp_category_id"/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- Simplified Requester Search View -->
    <record id="view_apricot_requester_search" model="ir.ui.view">
        <field name="name">apricot.ticket.requester.search</field>
        <field name="model">apricot.ticket.requester</field>
        <field name="arch" type="xml">
            <search string="Requesters">
                <field name="name"/>
                <field name="whatsapp_number"/>
                <field name="property_id"/>
                <field name="unit_number"/>

                <filter name="filter_terms_accepted"
                        string="Terms Accepted"
                        domain="[('terms_accepted', '=', True)]"/>

                <filter name="filter_terms_pending"
                        string="Terms Pending"
                        domain="[('terms_accepted', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Requester Action -->
    <record id="action_apricot_requesters" model="ir.actions.act_window">
        <field name="name">Requesters</field>
        <field name="res_model">apricot.ticket.requester</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_apricot_requester_search"/>
    </record>

</odoo>